# Copy to .env (or pass via install.py --org/--project). The MCP server reads these as defaults;
# every tool also accepts a per-call `org`, so these are optional conveniences.

# Default Azure DevOps organization URL
ADO_ORG=https://dev.azure.com/your-org

# Default project name (used by ado_pr_list_active)
ADO_PROJECT=Your Project

# Optional: path to the `az` binary if it is not on PATH
# AZ_BIN=/opt/homebrew/bin/az
